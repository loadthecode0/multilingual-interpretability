    "pt": {"flores": "por_Latn", "flores_plus": "por_Latn", "wmt": "pt", "opus100": "pt"},
    "ru": {"flores": "rus_Cyrl", "flores_plus": "rus_Cyrl", "wmt": "ru", "opus100": "ru"},
    "zh": {"flores": "zho_Hans", "flores_plus": "cmn_Hans", "wmt": "zh", "opus100": "zh"},
