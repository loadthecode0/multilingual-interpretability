    "en": {"flores": "eng_Latn", "flores_plus": "eng_Latn", "wmt": "en", "opus100": "en"},
    "fr": {"flores": "fra_Latn", "flores_plus": "fra_Latn", "wmt": "fr", "opus100": "fr"},
